<persistence xmlns="http://java.sun.com/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd"
             version="2.0">

    <persistence-unit name="test">
        <description>

        </description>

        <class>solvedit.model.User</class>

        <properties>
            <property name="javax.persistence.jdbc.driver" value="org.mysql.jdbc.JDBCDriver" />
            <property name="javax.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/solvedit;shutdown=true" />
            <property name="javax.persistence.jdbc.user" value="sa" />
            <property name="javax.persistence.jdbc.password" value="" />

            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.hbm2ddl.auto" value="create" />
        </properties>

    </persistence-unit>

</persistence>